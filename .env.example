# Dev server proxy target (used by vite.config.ts in local development only)
VITE_API_TARGET=http://localhost:3001

# Production API base URL — set this in your hosting platform (e.g. Vercel)
# Leave unset locally; the Vite proxy handles /api routes in dev
# VITE_API_BASE_URL=https://your-backend.onrender.com/api
